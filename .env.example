# 环境变量白名单与「已迁到数据库」的说明：见 docs/ENV_WHITELIST.md
# 业务可调参数优先在控制台：设置 → 认证 / 平台参数（platform_settings、auth_settings 表）

# NextAuth（生产必填；安装 Cookie 也可复用 NEXTAUTH_SECRET）
# 开发默认端口见 package.json 的 next dev（常见 3001）；须与浏览器访问地址一致
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# GitHub OAuth：请在控制台「认证设置」填写 Client ID / Secret（auth_settings），勿再使用 GITHUB_CLIENT_* 环境变量

# 安装完成 Cookie 单独密钥（可选）
# INSTALL_COOKIE_SECRET=

# WebAuthn（RP 细节可在认证设置中覆盖）
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Serverless Bot

# Upstash Redis REST（仅此两名；不配则用内存，重启丢）
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# KV_BACKEND=memory

# 安装 API：生产必填，请求头 x-install-secret 一致
# INSTALL_SECRET=

# 主库：见 docs/runbook/deployment.md
# DATABASE_ENGINE=libsql | nodejs-sqlite | mysql
# LIBSQL_URL=file:./local.db
# LIBSQL_AUTH_TOKEN=
# DATABASE_ENGINE=nodejs-sqlite
# SQLITE_PATH=file:./local.db

# MySQL（显式 DATABASE_ENGINE=mysql）
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=
# MYSQL_PASSWORD=
# MYSQL_DATABASE=

# 异步 Flow Worker / 去重队列等：队列行为在「平台参数」配置；以下为机密密钥（白名单）
# FLOW_WORKER_SECRET=
# CRON_TICK_SECRET=

# LLM Agent API Key 加密（可选；不填则用 NEXTAUTH_SECRET 派生密钥）
# AGENTS_ENCRYPTION_KEY=

# 开发环境危险 API 二次保护（可选）：x-dev-dangerous-secret
# DEV_DANGEROUS_API_SECRET=
